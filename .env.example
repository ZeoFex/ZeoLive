# Database (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js / NextAuth (required)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local:
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production (Vercel): set AUTH_URL and NEXT_PUBLIC_APP_URL to your live site URL

# Optional: allow extra LAN hosts for Next.js HMR when testing on a phone
# (comma-separated hostnames/IPs, no scheme). Example: 192.168.1.20,10.0.0.5
# ALLOWED_DEV_ORIGINS="172.20.10.6"

# SMTP (optional in local — reset links print to console if SMTP_PASS is unset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# LiveKit (classroom)
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
NEXT_PUBLIC_LIVEKIT_URL=""

# Cloudinary (uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional
# REDIS_URL=""
